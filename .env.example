# Google API (OAuth credentials for Gmail access)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_TOKEN_JSON=

# Gemini API (AI-powered email classification)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
USER_TELEGRAM_CHAT_ID=your_user_telegram_chat_id_here

# Database (PostgreSQL recommended for production, SQLite for local dev)
# PostgreSQL: postgresql://user:password@host:port/dbname
# SQLite:     sqlite:///./job_tracker.db
DATABASE_URL=postgresql://user:password@host:5432/dbname
